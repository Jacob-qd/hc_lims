.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1677ff;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.quick-actions {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.action-item {
  width: 22%;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
}

.icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin: 0 auto 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.action-item text {
  font-size: 22rpx;
  color: #666;
}

.stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.task-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.task-name {
  display: block;
  font-size: 28rpx;
}

.task-meta {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.task-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  color: #666;
}

.task-status.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.task-status.testing {
  background: #e6f7ff;
  color: #1677ff;
}

.empty {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
  font-size: 26rpx;
}
