.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.search {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
}

.report-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.report-title {
  font-size: 30rpx;
  font-weight: bold;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  color: #666;
}

.status.issued {
  background: #f6ffed;
  color: #52c41a;
}

.status.pending_approval {
  background: #e6f7ff;
  color: #1677ff;
}

.report-no {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.report-customer {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
}
